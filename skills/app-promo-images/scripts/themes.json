    "mono": {
      "decoration": "none",
      "fonts": { "headline": "Inter", "highlight": "Inter", "body": "Inter" },
      "tokens": {
        "--bg": "linear-gradient(180deg, #18181b 0%, #0b0b0f 100%)",
        "--bg-solid": "#0b0b0f",
        "--fg": "#fafafa",
        "--muted": "#a1a1aa",
        "--accent": "#fafafa",
        "--highlight": "#a1a1aa",
        "--bezel": "#000000",
        "--screen-bg": "#000000",
        "--badge-fg": "#0b0b0f",
