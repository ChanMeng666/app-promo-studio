{
  "_comment": "Theme presets. tokens become CSS custom properties on the slide root (and color/font choices for the SVG track). decoration draws background ornaments. Override --accent/--highlight via config.app.brandColor/accentColor.",
  "default": "purple-gradient",
  "themes": {
    "purple-gradient": {
      "decoration": "sparkles",
      "fonts": { "headline": "Inter", "highlight": "Fraunces", "body": "Inter" },
      "tokens": {
        "--bg": "radial-gradient(120% 120% at 50% 0%, #8b5cf6 0%, #6d28d9 38%, #3b1380 100%)",
        "--bg-solid": "#4c1d95",
        "--fg": "#ffffff",
        "--muted": "#e9d8fd",
        "--accent": "#c4b5fd",
        "--highlight": "#f3e8ff",
        "--bezel": "#0b0b14",
        "--screen-bg": "#15101f",
        "--badge-fg": "#3b1380",
        "--badge-bg": "#f3e8ff",
        "--deco": "#c4b5fd"
      }
    },
    "dark-playful": {
      "decoration": "blobs",
      "fonts": { "headline": "Baloo 2", "highlight": "Baloo 2", "body": "Inter" },
      "tokens": {
        "--bg": "linear-gradient(180deg, #20204a 0%, #161636 100%)",
        "--bg-solid": "#1b1b3a",
        "--fg": "#ffffff",
