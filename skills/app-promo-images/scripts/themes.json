        "--bg": "linear-gradient(180deg, #ffffff 0%, #eef1f6 100%)",
        "--bg-solid": "#f4f6fb",
        "--fg": "#0b0b12",
        "--muted": "#52525b",
        "--accent": "#0071e3",
        "--highlight": "#0071e3",
        "--bezel": "#0b0b14",
        "--screen-bg": "#0f0f17",
        "--badge-fg": "#ffffff",
        "--badge-bg": "#0b0b12",
        "--deco": "#c7d2fe"
